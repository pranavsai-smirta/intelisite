# Python
backend/.venv/
backend/__pycache__/
backend/**/__pycache__/
backend/.pytest_cache/
backend/*.pyc

# Env secrets — catch any .env at any depth
.env
**/.env
.env.*
**/.env.*
!**/.env.example

# Build artifacts
frontend/node_modules/
frontend/dist/
backend/artifacts/

# Certificates / private keys
*.pem
*.key
*.p12
*.pfx

# Docker runtime secrets
.env.docker

# Certbot — keep directory structure, ignore actual cert contents
certbot/conf/*
!certbot/conf/.gitkeep
certbot/www/*
!certbot/www/.gitkeep

# macOS
.DS_Store
